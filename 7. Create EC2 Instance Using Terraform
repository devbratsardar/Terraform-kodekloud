provider "aws" {
  region = "us-east-1"
}

# Get default VPC
data "aws_vpc" "default" {
  default = true
}

# Get default security group
data "aws_security_group" "default" {
  name   = "default"
  vpc_id = data.aws_vpc.default.id
}

# Generate RSA key
resource "tls_private_key" "datacenter" {
  algorithm = "RSA"
  rsa_bits  = 2048
}

# Create key pair in AWS
resource "aws_key_pair" "datacenter" {
  key_name   = "datacenter-kp"
  public_key = tls_private_key.datacenter.public_key_openssh
}

# Save private key locally
resource "local_file" "datacenter_pem" {
  filename        = "datacenter-kp.pem"
  content         = tls_private_key.datacenter.private_key_pem
  file_permission = "0400"
}

# Create EC2 instance
resource "aws_instance" "datacenter" {
  ami           = "ami-0c101f26f147fa7fd"
  instance_type = "t2.micro"

  key_name = aws_key_pair.datacenter.id

  vpc_security_group_ids = [
    data.aws_security_group.default.id
  ]

  tags = {
    Name = "datacenter-ec2"
  }
}
