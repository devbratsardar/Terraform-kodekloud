provider "aws" {
  region = "us-east-1"
}

# Create EC2 instance for monitoring
resource "aws_instance" "xfusion_ec2" {
  ami           = "ami-0c101f26f147fa7fd"
  instance_type = "t2.micro"

  tags = {
    Name = "xfusion-ec2"
  }
}

# Create CloudWatch alarm for CPU monitoring
resource "aws_cloudwatch_metric_alarm" "xfusion_alarm" {
  alarm_name                = "xfusion-alarm"
  comparison_operator       = "GreaterThanOrEqualToThreshold"
  evaluation_periods        = 1
  metric_name               = "CPUUtilization"
  namespace                 = "AWS/EC2"
  period                    = 300
  statistic                 = "Average"
  threshold                 = 80
  alarm_description = "CPU utilization exceeds 80% for 5 minutes"
  dimensions = {
    InstanceId = aws_instance.xfusion_ec2.id
  }
}
